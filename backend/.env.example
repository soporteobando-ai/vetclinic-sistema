# ── BASE DE DATOS ────────────────────────────────────────────────────────────
# DEV local con docker-compose:
#   DATABASE_URL="postgresql://vetclinic:vetclinic123@localhost:5432/veterinaria_db"
# PRODUCCIÓN (Neon — https://neon.tech):
#   DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/veterinaria_db?sslmode=require"
DATABASE_URL="postgresql://vetclinic:vetclinic123@localhost:5432/veterinaria_db"

# ── AUTENTICACIÓN ─────────────────────────────────────────────────────────────
# Generar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="reemplazar_con_secreto_aleatorio_de_64_chars"
JWT_EXPIRES_IN="7d"

# ── SERVIDOR ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# URL del frontend (sin barra final). En producción: URL de Vercel
FRONTEND_URL="http://localhost:5173"

# ── CLOUDINARY (imágenes) — https://cloudinary.com ───────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
